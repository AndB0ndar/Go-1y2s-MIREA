{
  "title": "Tasks Service Dashboard",
  "uid": "tasks-dashboard",
  "panels": [
    {
      "title": "RPS (requests per second)",
      "type": "graph",
      "targets": [
        {
          "expr": "rate(http_requests_total[1m])",
          "legendFormat": "{{method}} {{route}} {{status}}"
        }
      ],
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0}
    },
    {
      "title": "Error rate (4xx/5xx)",
      "type": "graph",
      "targets": [
        {
          "expr": "rate(http_requests_total{status=~\"4..\"}[1m])",
          "legendFormat": "4xx"
        },
        {
          "expr": "rate(http_requests_total{status=~\"5..\"}[1m])",
          "legendFormat": "5xx"
        }
      ],
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0}
    },
    {
      "title": "Latency p95",
      "type": "graph",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[1m])) by (le, method, route))",
          "legendFormat": "{{method}} {{route}}"
        }
      ],
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 8}
    }
  ],
  "schemaVersion": 27,
  "version": 1
}
